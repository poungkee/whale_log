# Google OAuth 클라이언트 ID (Google Cloud Console에서 발급)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Kakao JavaScript 키 (Kakao Developers에서 발급)
VITE_KAKAO_JS_KEY=your-kakao-js-key

# Kakao REST API 키 (Kakao Developers에서 발급)
VITE_KAKAO_REST_API_KEY=your-kakao-rest-api-key

# API 서버 URL (프로덕션용 - Capacitor 빌드 시 사용)
# VITE_API_BASE_URL=https://api.your-domain.com
