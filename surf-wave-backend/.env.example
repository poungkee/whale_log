# ===== 데이터베이스 =====
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=surfwave
DB_PASSWORD=your-strong-db-password-here
DB_DATABASE=surfwave
# DB_SSL_REJECT_UNAUTHORIZED=false  # 자체 서명 인증서 환경에서만 사용
# DB_POOL_SIZE=20

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# ===== JWT 인증 (프로덕션 필수!) =====
# 최소 32자 이상 랜덤 문자열 권장: openssl rand -base64 48
JWT_SECRET=your-strong-jwt-secret-here

# ===== Kakao OAuth =====
KAKAO_REST_API_KEY=your-kakao-rest-api-key
# KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ===== Firebase (FCM 푸시 알림용, 선택) =====
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ===== AWS S3 (파일 업로드용, 선택) =====
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=surfwave-uploads

# ===== CORS (프로덕션 필수!) =====
# 허용할 프론트엔드 도메인 (쉼표 구분)
# ALLOWED_ORIGINS=https://your-app.com,https://www.your-app.com

# ===== 앱 설정 =====
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1
